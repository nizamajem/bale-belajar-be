generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PilotStatus {
  PROSPECT
  CONTACTED
  DEMO
  ACTIVE_PILOT
  EVALUATION
  COMPLETED
  DISCONTINUED
}

enum LeadStatus {
  NEW
  CONTACTED
  DEMO_SCHEDULED
  PILOT
  REJECTED
  CONVERTED
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionType {
  MULTIPLE_CHOICE
  MULTIPLE_CHOICE_IMAGE
}

enum QuestionStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum AssessmentStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  CLOSED
  ARCHIVED
}

enum AssignmentStatus {
  ASSIGNED
  STARTED
  COMPLETED
  EXPIRED
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  AUTO_SUBMITTED
  CANCELLED
}

enum MasteryStatus {
  MASTERED
  DEVELOPING
  NEEDS_PRACTICE
}

enum RecommendationGeneratedBy {
  RULE_ENGINE
  MANUAL
  AI_FUTURE
}

enum MissionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ActivityType {
  MULTIPLE_CHOICE
}

enum LearningMasteryStatus {
  MASTERED
  DEVELOPING
  NEEDS_PRACTICE
  INSUFFICIENT_EVIDENCE
}

enum ConfidenceLevel {
  HIGH
  MEDIUM
  LOW
}

enum XpReason {
  MISSION_COMPLETED
  ACTIVITY_CORRECT
  STREAK_BONUS
  MANUAL_ADJUSTMENT
}

enum AiFeature {
  MISSION_NARRATIVE
  ACTIVITY_HINT
}

enum GuardrailStatus {
  PASSED
  BLOCKED
  FALLBACK
}

enum CareerPath {
  DETECTIVE
  ANIMAL_DOCTOR
  KOREAN_TEACHER
}

enum EvidenceRelevance {
  RELEVANT
  PARTIAL
  DISTRACTOR
}

enum EvidenceStrength {
  HIGH
  MEDIUM
  LOW
}

enum ConfidenceDeclaration {
  HIGH
  MEDIUM
  LOW
  INSUFFICIENT_EVIDENCE
}

model User {
  id               String    @id @default(uuid()) @db.Uuid
  name             String
  email            String?   @unique
  phone            String?
  passwordHash     String?
  firebaseUid      String?   @unique
  avatarUrl        String?
  role             UserRole
  // Peran tambahan yang boleh dipakai user ini lewat pindah peran (mis.
  // siswa yang juga guru). `role` di atas tetap peran utama/default saat
  // login pertama kali; ini murni daftar peran ekstra yang tersedia.
  additionalRoles  UserRole[] @default([])
  status           UserStatus @default(ACTIVE)
  refreshTokenHash String?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  teacherProfile TeacherProfile?
  studentProfile StudentProfile?
  auditLogs      AuditLog[]
  questions      Question[]
  assessments    Assessment[]
  parentReports  ParentReport[]

  @@index([role])
  @@index([deletedAt])
}

model School {
  id           String      @id @default(uuid()) @db.Uuid
  name         String
  npsn         String?
  slug         String      @unique
  address      String
  province     String
  city         String
  district     String?
  contactName  String?
  contactPhone String?
  contactEmail String?
  logoUrl      String?
  pilotStatus  PilotStatus @default(PROSPECT)
  pilotStartDate DateTime?
  pilotEndDate DateTime?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  teachers   TeacherProfile[]
  students   StudentProfile[]
  classrooms Classroom[]
  assessments Assessment[]

  @@index([city])
  @@index([pilotStatus])
  @@index([deletedAt])
}

model TeacherProfile {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @unique @db.Uuid
  schoolId              String   @db.Uuid
  employeeNumber        String?
  subjectSpecialization String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  school School @relation(fields: [schoolId], references: [id])
  homeroomClassrooms Classroom[]

  @@index([schoolId])
}

model StudentProfile {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String?   @unique @db.Uuid
  schoolId        String?   @db.Uuid
  participantCode String?   @unique
  studentNumber   String?
  fullName        String
  phone           String?
  gender          String?
  birthDate       DateTime?
  academicYear    String?
  gradeLevel      Int?
  careerPath      CareerPath?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  user   User?   @relation(fields: [userId], references: [id])
  school School? @relation(fields: [schoolId], references: [id])
  classrooms ClassroomStudent[]
  assignments AssessmentAssignment[]
  gameProfile StudentGameProfile?
  worldProgress StudentWorldProgress[]
  experienceEntries ExperienceLedgerEntry[]
  masteryStates MasteryState[]
  masteryEvents MasteryEvent[]
  missionAssignments DailyMissionAssignment[]
  aiInteractionLogs AiInteractionLog[]
  caseAssignments CaseAssignment[]

  @@index([schoolId])
  @@index([academicYear])
  @@index([deletedAt])
}

model Classroom {
  id                String   @id @default(uuid()) @db.Uuid
  schoolId          String   @db.Uuid
  name              String
  gradeLevel        Int
  academicYear      String
  homeroomTeacherId String?  @db.Uuid
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  school          School          @relation(fields: [schoolId], references: [id])
  homeroomTeacher TeacherProfile? @relation(fields: [homeroomTeacherId], references: [id])
  students        ClassroomStudent[]
  assessments     AssessmentClassroom[]

  @@unique([schoolId, name, academicYear])
  @@index([schoolId])
}

model ClassroomStudent {
  id          String    @id @default(uuid()) @db.Uuid
  classroomId String    @db.Uuid
  studentId   String    @db.Uuid
  joinedAt    DateTime  @default(now())
  leftAt      DateTime?

  classroom Classroom      @relation(fields: [classroomId], references: [id])
  student   StudentProfile @relation(fields: [studentId], references: [id])

  @@unique([classroomId, studentId])
  @@index([studentId])
}

model Subject {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  competencies Competency[]
  questions    Question[]
  assessments  Assessment[]
  worlds       World[]
}

model Competency {
  id          String   @id @default(uuid()) @db.Uuid
  subjectId   String   @db.Uuid
  code        String
  name        String
  description String?
  gradeLevel  Int?
  orderNumber Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subject       Subject @relation(fields: [subjectId], references: [id])
  subCompetencies SubCompetency[]
  questions     Question[]
  prerequisites CompetencyPrerequisite[] @relation("CompetencyPrerequisites")
  requiredBy    CompetencyPrerequisite[] @relation("PrerequisiteCompetencies")
  competencyResults CompetencyResult[]
  recommendations LearningRecommendation[]
  missions      Mission[]
  masteryStates MasteryState[]
  masteryEvents MasteryEvent[]
  caseQuestions CaseQuestion[]

  @@unique([subjectId, code])
  @@index([subjectId])
  @@index([gradeLevel])
}

model SubCompetency {
  id           String   @id @default(uuid()) @db.Uuid
  competencyId String   @db.Uuid
  code         String
  name         String
  description  String?
  orderNumber  Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  competency Competency @relation(fields: [competencyId], references: [id])
  questions  Question[]

  @@unique([competencyId, code])
  @@index([competencyId])
}

model CompetencyPrerequisite {
  id                       String @id @default(uuid()) @db.Uuid
  competencyId             String @db.Uuid
  prerequisiteCompetencyId String @db.Uuid

  competency             Competency @relation("CompetencyPrerequisites", fields: [competencyId], references: [id])
  prerequisiteCompetency Competency @relation("PrerequisiteCompetencies", fields: [prerequisiteCompetencyId], references: [id])

  @@unique([competencyId, prerequisiteCompetencyId])
  @@index([prerequisiteCompetencyId])
}

model Question {
  id               String             @id @default(uuid()) @db.Uuid
  code             String             @unique
  subjectId        String             @db.Uuid
  competencyId     String             @db.Uuid
  subCompetencyId  String?            @db.Uuid
  gradeLevel       Int
  difficulty       QuestionDifficulty
  type             QuestionType
  questionText     String
  explanation      String?
  imageUrl         String?
  weight           Decimal            @default(1) @db.Decimal(8, 2)
  source           String?
  status           QuestionStatus     @default(DRAFT)
  createdBy        String?            @db.Uuid
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?

  subject       Subject        @relation(fields: [subjectId], references: [id])
  competency    Competency     @relation(fields: [competencyId], references: [id])
  subCompetency SubCompetency? @relation(fields: [subCompetencyId], references: [id])
  creator       User?          @relation(fields: [createdBy], references: [id])
  options       QuestionOption[]
  assessments   AssessmentQuestion[]
  answers       StudentAnswer[]

  @@index([subjectId])
  @@index([competencyId])
  @@index([status])
  @@index([deletedAt])
}

model QuestionOption {
  id          String  @id @default(uuid()) @db.Uuid
  questionId  String  @db.Uuid
  optionKey   String
  optionText  String
  imageUrl    String?
  isCorrect   Boolean @default(false)
  orderNumber Int

  question Question @relation(fields: [questionId], references: [id])
  answers  StudentAnswer[]

  @@unique([questionId, optionKey])
  @@index([questionId])
}

model SchoolLead {
  id           String     @id @default(uuid()) @db.Uuid
  schoolName   String
  contactName  String
  position     String?
  phone        String
  email        String?
  studentCount Int?
  message      String?
  source       String?
  status       LeadStatus @default(NEW)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Assessment {
  id                    String           @id @default(uuid()) @db.Uuid
  schoolId              String?          @db.Uuid
  subjectId             String           @db.Uuid
  title                 String
  slug                  String
  description           String?
  gradeLevel            Int
  durationMinutes       Int?
  startAt               DateTime?
  endAt                 DateTime?
  accessCode            String?
  showResultImmediately Boolean          @default(true)
  allowRetake           Boolean          @default(false)
  maxAttempts           Int              @default(1)
  status                AssessmentStatus @default(DRAFT)
  createdBy             String?          @db.Uuid
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  deletedAt             DateTime?

  school      School?                @relation(fields: [schoolId], references: [id])
  subject     Subject                @relation(fields: [subjectId], references: [id])
  creator     User?                  @relation(fields: [createdBy], references: [id])
  questions   AssessmentQuestion[]
  classrooms  AssessmentClassroom[]
  assignments AssessmentAssignment[]

  @@unique([subjectId, slug])
  @@index([schoolId])
  @@index([subjectId])
  @@index([status])
  @@index([deletedAt])
}

model AssessmentQuestion {
  id             String   @id @default(uuid()) @db.Uuid
  assessmentId   String   @db.Uuid
  questionId     String   @db.Uuid
  orderNumber    Int
  weightOverride Decimal? @db.Decimal(8, 2)

  assessment Assessment @relation(fields: [assessmentId], references: [id])
  question   Question   @relation(fields: [questionId], references: [id])

  @@unique([assessmentId, questionId])
  @@unique([assessmentId, orderNumber])
  @@index([questionId])
}

model AssessmentClassroom {
  id           String @id @default(uuid()) @db.Uuid
  assessmentId String @db.Uuid
  classroomId  String @db.Uuid

  assessment Assessment @relation(fields: [assessmentId], references: [id])
  classroom  Classroom  @relation(fields: [classroomId], references: [id])

  @@unique([assessmentId, classroomId])
  @@index([classroomId])
}

model AssessmentAssignment {
  id           String           @id @default(uuid()) @db.Uuid
  assessmentId String           @db.Uuid
  studentId    String           @db.Uuid
  assignedAt   DateTime         @default(now())
  dueAt        DateTime?
  status       AssignmentStatus @default(ASSIGNED)

  assessment Assessment          @relation(fields: [assessmentId], references: [id])
  student    StudentProfile      @relation(fields: [studentId], references: [id])
  attempts   AssessmentAttempt[]

  @@unique([assessmentId, studentId])
  @@index([studentId])
  @@index([status])
}

model AssessmentAttempt {
  id              String        @id @default(uuid()) @db.Uuid
  assignmentId    String        @db.Uuid
  attemptNumber   Int
  startedAt       DateTime      @default(now())
  submittedAt     DateTime?
  durationSeconds Int?
  totalScore      Decimal?      @db.Decimal(8, 2)
  correctAnswers  Int?
  wrongAnswers    Int?
  unanswered      Int?
  status          AttemptStatus @default(IN_PROGRESS)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  assignment        AssessmentAssignment @relation(fields: [assignmentId], references: [id])
  answers           StudentAnswer[]
  competencyResults CompetencyResult[]
  recommendations   LearningRecommendation[]
  parentReports     ParentReport[]

  @@unique([assignmentId, attemptNumber])
  @@index([status])
}

model StudentAnswer {
  id               String   @id @default(uuid()) @db.Uuid
  attemptId        String   @db.Uuid
  questionId       String   @db.Uuid
  selectedOptionId String?  @db.Uuid
  isCorrect        Boolean?
  score            Decimal? @db.Decimal(8, 2)
  isMarkedForReview Boolean @default(false)
  answeredAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  attempt        AssessmentAttempt @relation(fields: [attemptId], references: [id])
  question       Question          @relation(fields: [questionId], references: [id])
  selectedOption QuestionOption?   @relation(fields: [selectedOptionId], references: [id])

  @@unique([attemptId, questionId])
  @@index([questionId])
}

model CompetencyResult {
  id                  String        @id @default(uuid()) @db.Uuid
  attemptId           String        @db.Uuid
  competencyId        String        @db.Uuid
  totalQuestionWeight Decimal       @db.Decimal(8, 2)
  correctWeight       Decimal       @db.Decimal(8, 2)
  score               Decimal       @db.Decimal(8, 2)
  masteryStatus       MasteryStatus
  createdAt           DateTime      @default(now())

  attempt    AssessmentAttempt @relation(fields: [attemptId], references: [id])
  competency Competency        @relation(fields: [competencyId], references: [id])

  @@unique([attemptId, competencyId])
  @@index([competencyId])
}

model LearningRecommendation {
  id              String                    @id @default(uuid()) @db.Uuid
  attemptId       String                    @db.Uuid
  competencyId    String                    @db.Uuid
  priority        Int
  title           String
  description     String
  recommendedDays Int
  generatedBy     RecommendationGeneratedBy @default(RULE_ENGINE)
  snapshotData    Json
  createdAt       DateTime                  @default(now())

  attempt    AssessmentAttempt @relation(fields: [attemptId], references: [id])
  competency Competency        @relation(fields: [competencyId], references: [id])

  @@unique([attemptId, priority])
  @@index([competencyId])
}

model ParentReport {
  id         String   @id @default(uuid()) @db.Uuid
  attemptId  String   @db.Uuid
  summary    String
  pdfUrl     String?
  shareToken String?  @unique
  generatedAt DateTime @default(now())
  createdBy  String?  @db.Uuid

  attempt AssessmentAttempt @relation(fields: [attemptId], references: [id])
  creator User?             @relation(fields: [createdBy], references: [id])

  @@index([attemptId])
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  action    String
  entity    String
  entityId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// =========================================================================
// BaleTeman / BaleVerse domain (game layer, learning layer, mastery layer,
// AI orchestration layer) — additive, dibangun di atas User/StudentProfile/
// Subject/Competency yang sudah ada. Terpisah dari Assessment/CompetencyResult
// (ujian formal sekolah) supaya XP, mastery harian, dan skor ujian formal
// tidak pernah tercampur dalam satu sumber data.
// =========================================================================

model World {
  id               String   @id @default(uuid()) @db.Uuid
  subjectId        String   @db.Uuid
  key              String   @unique
  name             String
  characterClass   String
  themeDescription String?
  isActive         Boolean  @default(true)
  orderNumber      Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  subject             Subject                   @relation(fields: [subjectId], references: [id])
  worldProgress       StudentWorldProgress[]
  experienceEntries   ExperienceLedgerEntry[]
  missions            Mission[]
  missionAssignments  DailyMissionAssignment[]
  caseMissions        CaseMission[]
  caseAssignments     CaseAssignment[]

  @@index([subjectId])
}

model StudentGameProfile {
  id                  String   @id @default(uuid()) @db.Uuid
  studentProfileId    String   @unique @db.Uuid
  accountLevel        Int      @default(1)
  accountXp           Int      @default(0)
  dayaBale            Int      @default(0)
  streakCurrent       Int      @default(0)
  streakLongest       Int      @default(0)
  streakTargetPerWeek Int      @default(3)
  lastActivityDate    DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  student StudentProfile @relation(fields: [studentProfileId], references: [id])
}

model StudentWorldProgress {
  id               String   @id @default(uuid()) @db.Uuid
  studentProfileId String   @db.Uuid
  worldId          String   @db.Uuid
  worldLevel       Int      @default(1)
  worldXp          Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  student StudentProfile @relation(fields: [studentProfileId], references: [id])
  world   World          @relation(fields: [worldId], references: [id])

  @@unique([studentProfileId, worldId])
  @@index([worldId])
}

model ExperienceLedgerEntry {
  id               String   @id @default(uuid()) @db.Uuid
  studentProfileId String   @db.Uuid
  worldId          String?  @db.Uuid
  amount           Int
  reason           XpReason
  sourceType       String
  sourceId         String?
  createdAt        DateTime @default(now())

  student StudentProfile @relation(fields: [studentProfileId], references: [id])
  world   World?          @relation(fields: [worldId], references: [id])

  @@index([studentProfileId])
  @@index([worldId])
}

model MasteryState {
  id               String                @id @default(uuid()) @db.Uuid
  studentProfileId String                @db.Uuid
  competencyId     String                @db.Uuid
  masteryScore     Decimal               @default(0) @db.Decimal(5, 2)
  status           LearningMasteryStatus @default(INSUFFICIENT_EVIDENCE)
  confidence       ConfidenceLevel       @default(LOW)
  evidenceCount    Int                   @default(0)
  scoringVersion   Int                   @default(1)
  lastEvaluatedAt  DateTime              @default(now())
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  student    StudentProfile @relation(fields: [studentProfileId], references: [id])
  competency Competency     @relation(fields: [competencyId], references: [id])
  events     MasteryEvent[]

  @@unique([studentProfileId, competencyId])
  @@index([competencyId])
}

model MasteryEvent {
  id               String                @id @default(uuid()) @db.Uuid
  masteryStateId   String                @db.Uuid
  studentProfileId String                @db.Uuid
  competencyId     String                @db.Uuid
  scoreDelta       Decimal               @db.Decimal(5, 2)
  newScore         Decimal               @db.Decimal(5, 2)
  newStatus        LearningMasteryStatus
  confidence       ConfidenceLevel
  scoringVersion   Int
  sourceType       String
  sourceId         String
  createdAt        DateTime              @default(now())

  masteryState MasteryState    @relation(fields: [masteryStateId], references: [id])
  student      StudentProfile  @relation(fields: [studentProfileId], references: [id])
  competency   Competency      @relation(fields: [competencyId], references: [id])

  @@index([masteryStateId])
  @@index([studentProfileId])
}

model Mission {
  id                String        @id @default(uuid()) @db.Uuid
  worldId           String        @db.Uuid
  competencyId      String        @db.Uuid
  title             String
  narrativeTemplate String
  estimatedMinutes  Int           @default(10)
  status            MissionStatus @default(DRAFT)
  createdBy         String?       @db.Uuid
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  world       World                    @relation(fields: [worldId], references: [id])
  competency  Competency               @relation(fields: [competencyId], references: [id])
  activities  Activity[]
  assignments DailyMissionAssignment[]

  @@index([worldId])
  @@index([competencyId])
  @@index([status])
}

model Activity {
  id          String       @id @default(uuid()) @db.Uuid
  missionId   String       @db.Uuid
  orderNumber Int
  prompt      String
  type        ActivityType @default(MULTIPLE_CHOICE)
  explanation String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  mission Mission          @relation(fields: [missionId], references: [id])
  options ActivityOption[]
  answers MissionActivityAnswer[]

  @@unique([missionId, orderNumber])
}

model ActivityOption {
  id          String  @id @default(uuid()) @db.Uuid
  activityId  String  @db.Uuid
  optionKey   String
  optionText  String
  isCorrect   Boolean @default(false)
  orderNumber Int

  activity Activity                @relation(fields: [activityId], references: [id])
  answers  MissionActivityAnswer[]

  @@unique([activityId, optionKey])
}

model DailyMissionAssignment {
  id               String           @id @default(uuid()) @db.Uuid
  studentProfileId String           @db.Uuid
  worldId          String           @db.Uuid
  missionId        String           @db.Uuid
  assignedDate     DateTime         @db.Date
  status           AssignmentStatus @default(ASSIGNED)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  student StudentProfile  @relation(fields: [studentProfileId], references: [id])
  world   World           @relation(fields: [worldId], references: [id])
  mission Mission         @relation(fields: [missionId], references: [id])
  attempt MissionAttempt?

  @@unique([studentProfileId, worldId, assignedDate])
  @@index([missionId])
}

model MissionAttempt {
  id                        String        @id @default(uuid()) @db.Uuid
  dailyMissionAssignmentId  String        @unique @db.Uuid
  status                    AttemptStatus @default(IN_PROGRESS)
  startedAt                 DateTime      @default(now())
  submittedAt               DateTime?
  correctCount              Int?
  totalActivities           Int?
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt

  assignment DailyMissionAssignment  @relation(fields: [dailyMissionAssignmentId], references: [id])
  answers    MissionActivityAnswer[]

  @@index([status])
}

model MissionActivityAnswer {
  id               String    @id @default(uuid()) @db.Uuid
  missionAttemptId String    @db.Uuid
  activityId       String    @db.Uuid
  selectedOptionId String?   @db.Uuid
  isCorrect        Boolean?
  answeredAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  attempt        MissionAttempt  @relation(fields: [missionAttemptId], references: [id])
  activity       Activity        @relation(fields: [activityId], references: [id])
  selectedOption ActivityOption? @relation(fields: [selectedOptionId], references: [id])

  @@unique([missionAttemptId, activityId])
  @@index([activityId])
}

model AiInteractionLog {
  id               String          @id @default(uuid()) @db.Uuid
  studentProfileId String?         @db.Uuid
  feature          AiFeature
  provider         String
  promptVersion    String
  requestSummary   Json
  responseSummary  Json
  guardrailStatus  GuardrailStatus
  latencyMs        Int
  createdAt        DateTime        @default(now())

  student StudentProfile? @relation(fields: [studentProfileId], references: [id])

  @@index([studentProfileId])
  @@index([feature])
}

// =========================================================================
// BaleDetective: Case Mission (evidence-based investigation missions).
// Bentuknya beda dari Mission/Activity (pilihan ganda) di Numeria - di sini
// siswa membaca bukti, menjawab pertanyaan penalaran secara bebas teks, dan
// menulis kesimpulan + tingkat keyakinan. Skill Mastery & XP tetap pakai
// Competency/MasteryState/ExperienceLedgerEntry yang sudah ada (reuse penuh).
// =========================================================================

model CaseMission {
  id               String        @id @default(uuid()) @db.Uuid
  worldId          String        @db.Uuid
  title            String
  openingStory     String
  estimatedMinutes Int           @default(20)
  status           MissionStatus @default(DRAFT)
  createdBy        String?       @db.Uuid
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  world       World            @relation(fields: [worldId], references: [id])
  evidence    CaseEvidence[]
  questions   CaseQuestion[]
  assignments CaseAssignment[]

  @@index([worldId])
  @@index([status])
}

model CaseEvidence {
  id             String            @id @default(uuid()) @db.Uuid
  caseMissionId  String            @db.Uuid
  orderNumber    Int
  type           String
  content        String
  relevance      EvidenceRelevance
  sourceStrength EvidenceStrength
  createdAt      DateTime          @default(now())

  caseMission CaseMission @relation(fields: [caseMissionId], references: [id])

  @@unique([caseMissionId, orderNumber])
}

model CaseQuestion {
  id                String   @id @default(uuid()) @db.Uuid
  caseMissionId     String   @db.Uuid
  competencyId      String   @db.Uuid
  orderNumber       Int
  prompt            String
  expectedKeywords  String[]
  expectedReasoning String
  createdAt         DateTime @default(now())

  caseMission CaseMission  @relation(fields: [caseMissionId], references: [id])
  competency  Competency   @relation(fields: [competencyId], references: [id])
  answers     CaseAnswer[]

  @@unique([caseMissionId, orderNumber])
  @@index([competencyId])
}

model CaseAssignment {
  id               String           @id @default(uuid()) @db.Uuid
  studentProfileId String           @db.Uuid
  worldId          String           @db.Uuid
  caseMissionId    String           @db.Uuid
  assignedDate     DateTime         @db.Date
  status           AssignmentStatus @default(ASSIGNED)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  student     StudentProfile @relation(fields: [studentProfileId], references: [id])
  world       World          @relation(fields: [worldId], references: [id])
  caseMission CaseMission    @relation(fields: [caseMissionId], references: [id])
  attempt     CaseAttempt?

  @@unique([studentProfileId, worldId, assignedDate])
  @@index([caseMissionId])
}

model CaseAttempt {
  id               String                 @id @default(uuid()) @db.Uuid
  caseAssignmentId String                 @unique @db.Uuid
  status           AttemptStatus          @default(IN_PROGRESS)
  startedAt        DateTime               @default(now())
  submittedAt      DateTime?
  conclusionText   String?
  confidenceLevel  ConfidenceDeclaration?
  overallScore     Decimal?               @db.Decimal(5, 2)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  assignment CaseAssignment @relation(fields: [caseAssignmentId], references: [id])
  answers    CaseAnswer[]

  @@index([status])
}

model CaseAnswer {
  id              String    @id @default(uuid()) @db.Uuid
  caseAttemptId   String    @db.Uuid
  caseQuestionId  String    @db.Uuid
  answerText      String?
  score           Decimal?  @db.Decimal(5, 2)
  matchedKeywords String[]
  answeredAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  attempt  CaseAttempt  @relation(fields: [caseAttemptId], references: [id])
  question CaseQuestion @relation(fields: [caseQuestionId], references: [id])

  @@unique([caseAttemptId, caseQuestionId])
  @@index([caseQuestionId])
}
